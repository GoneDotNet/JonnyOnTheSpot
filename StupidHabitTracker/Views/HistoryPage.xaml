<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:StupidHabitTracker.ViewModels"
             xmlns:models="clr-namespace:StupidHabitTracker.Models"
             x:Class="StupidHabitTracker.Views.HistoryPage"
             x:DataType="vm:HistoryViewModel"
             Title="History"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*" Padding="24,60,24,24" BackgroundColor="{StaticResource BackgroundLight}">

        <!-- Header -->
        <VerticalStackLayout Grid.Row="0" Spacing="4" Padding="0,0,0,16">
            <Label Text="History"
                   Style="{StaticResource TitleLabel}"
                   FontSize="32" />
            <Label Text="Your completed sessions"
                   Style="{StaticResource SubtitleLabel}" />
        </VerticalStackLayout>

        <!-- Empty State -->
        <VerticalStackLayout Grid.Row="1"
                             IsVisible="{Binding IsEmpty}"
                             VerticalOptions="Center"
                             HorizontalOptions="Center"
                             Spacing="12">
            <Label Text="🕐"
                   FontSize="64"
                   HorizontalTextAlignment="Center" />
            <Label Text="No sessions yet"
                   Style="{StaticResource SubtitleLabel}"
                   HorizontalTextAlignment="Center" />
            <Label Text="Start timing a habit to see your history here"
                   Style="{StaticResource CaptionLabel}"
                   HorizontalTextAlignment="Center" />
        </VerticalStackLayout>

        <!-- Session List -->
        <CollectionView Grid.Row="1"
                         ItemsSource="{Binding SessionGroups}"
                         IsGrouped="True"
                         IsVisible="{Binding IsEmpty, Converter={StaticResource BoolInverse}}">

            <CollectionView.GroupHeaderTemplate>
                <DataTemplate x:DataType="vm:SessionGroup">
                    <Label Text="{Binding DateHeader}"
                           Style="{StaticResource CaptionLabel}"
                           FontAttributes="Bold"
                           FontSize="14"
                           Margin="4,16,0,8"
                           TextTransform="Uppercase" />
                </DataTemplate>
            </CollectionView.GroupHeaderTemplate>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:TimedSession">
                    <SwipeView>
                        <SwipeView.RightItems>
                            <SwipeItems>
                                <SwipeItem Text="Delete"
                                           BackgroundColor="{StaticResource Danger}"
                                           Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HistoryViewModel}}, Path=DeleteSessionCommand}"
                                           CommandParameter="{Binding .}" />
                            </SwipeItems>
                        </SwipeView.RightItems>

                        <Frame Style="{StaticResource Card}" Margin="0,0,0,8" Padding="16">
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                                <!-- Habit Name -->
                                <Label Grid.Row="0" Grid.Column="0"
                                       Text="{Binding HabitName}"
                                       Style="{StaticResource BodyLabel}"
                                       FontAttributes="Bold"
                                       FontSize="17" />

                                <!-- Duration -->
                                <Label Grid.Row="0" Grid.Column="1"
                                       Text="{Binding DurationSeconds, Converter={StaticResource DurationDisplay}}"
                                       Style="{StaticResource BodyLabel}"
                                       TextColor="{StaticResource Primary}"
                                       FontAttributes="Bold"
                                       VerticalTextAlignment="Center" />

                                <!-- Time Range -->
                                <Label Grid.Row="1" Grid.Column="0"
                                       Style="{StaticResource CaptionLabel}"
                                       Margin="0,4,0,0">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="{Binding StartTime, StringFormat='{0:h:mm tt}'}" />
                                            <Span Text=" — " />
                                            <Span Text="{Binding EndTime, StringFormat='{0:h:mm tt}'}" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                            </Grid>
                        </Frame>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>

</ContentPage>
