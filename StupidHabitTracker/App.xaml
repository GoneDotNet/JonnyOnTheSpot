<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:StupidHabitTracker.Converters"
             x:Class="StupidHabitTracker.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters -->
            <converters:BoolToInverseConverter x:Key="BoolInverse" />
            <converters:DurationConverter x:Key="DurationDisplay" />
            <converters:DateGroupHeaderConverter x:Key="DateGroupHeader" />
            <converters:IntToBoolConverter x:Key="IntToBool" />
            <converters:PauseResumeTextConverter x:Key="PauseResumeText" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
