<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Page Style -->
    <Style TargetType="Page" ApplyToDerivedTypes="True">
        <Setter Property="BackgroundColor" Value="{StaticResource BackgroundLight}" />
    </Style>

    <Style TargetType="Shell" ApplyToDerivedTypes="True">
        <Setter Property="Shell.BackgroundColor" Value="{StaticResource Primary}" />
        <Setter Property="Shell.ForegroundColor" Value="White" />
        <Setter Property="Shell.TabBarBackgroundColor" Value="{StaticResource SurfaceLight}" />
        <Setter Property="Shell.TabBarForegroundColor" Value="{StaticResource Primary}" />
        <Setter Property="Shell.TabBarUnselectedColor" Value="{StaticResource TextTertiaryLight}" />
        <Setter Property="Shell.TitleColor" Value="White" />
    </Style>

    <Style TargetType="NavigationPage" ApplyToDerivedTypes="True">
        <Setter Property="BarBackgroundColor" Value="{StaticResource Primary}" />
        <Setter Property="BarTextColor" Value="White" />
    </Style>

    <!-- Label Styles -->
    <Style x:Key="TitleLabel" TargetType="Label">
        <Setter Property="FontSize" Value="28" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimaryLight}" />
    </Style>

    <Style x:Key="SubtitleLabel" TargetType="Label">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="TextColor" Value="{StaticResource TextSecondaryLight}" />
    </Style>

    <Style x:Key="BodyLabel" TargetType="Label">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimaryLight}" />
    </Style>

    <Style x:Key="CaptionLabel" TargetType="Label">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="TextColor" Value="{StaticResource TextSecondaryLight}" />
    </Style>

    <Style x:Key="TimerDisplay" TargetType="Label">
        <Setter Property="FontSize" Value="56" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimaryLight}" />
    </Style>

    <!-- Entry Style -->
    <Style x:Key="HabitEntry" TargetType="Entry">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceLight}" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimaryLight}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource TextTertiaryLight}" />
        <Setter Property="Margin" Value="0" />
    </Style>

    <!-- Button Styles -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="HeightRequest" Value="56" />
        <Setter Property="Padding" Value="24,0" />
    </Style>

    <Style x:Key="StartButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource Success}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="CornerRadius" Value="40" />
        <Setter Property="HeightRequest" Value="80" />
        <Setter Property="WidthRequest" Value="80" />
    </Style>

    <Style x:Key="StopButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource Danger}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="CornerRadius" Value="40" />
        <Setter Property="HeightRequest" Value="80" />
        <Setter Property="WidthRequest" Value="80" />
    </Style>

    <!-- Card Style -->
    <Style x:Key="Card" TargetType="Frame">
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceLight}" />
        <Setter Property="BorderColor" Value="{StaticResource BorderLight}" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="HasShadow" Value="False" />
    </Style>

    <Style x:Key="StatCard" TargetType="Frame">
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceLight}" />
        <Setter Property="BorderColor" Value="{StaticResource BorderLight}" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="HasShadow" Value="False" />
    </Style>

    <!-- Chip Button for recent habits -->
    <Style x:Key="ChipButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource PrimaryLight}" />
        <Setter Property="TextColor" Value="{StaticResource Primary}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="CornerRadius" Value="20" />
        <Setter Property="HeightRequest" Value="36" />
        <Setter Property="Padding" Value="16,0" />
        <Setter Property="BorderWidth" Value="0" />
    </Style>

    <!-- Default styles for controls -->
    <Style TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource TextPrimaryLight}" />
    </Style>

    <Style TargetType="Entry">
        <Setter Property="TextColor" Value="{StaticResource TextPrimaryLight}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource TextTertiaryLight}" />
    </Style>

</ResourceDictionary>
