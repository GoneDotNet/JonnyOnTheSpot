<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="StupidHabitTracker.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:StupidHabitTracker.Views"
    Title="Habit Tracker">

    <TabBar>
        <ShellContent
            Title="Timer"
            Icon="{OnPlatform iOS='timer', Default='timer'}"
            ContentTemplate="{DataTemplate views:TimerPage}"
            Route="TimerPage" />
        <ShellContent
            Title="History"
            Icon="{OnPlatform iOS='clock', Default='clock'}"
            ContentTemplate="{DataTemplate views:HistoryPage}"
            Route="HistoryPage" />
        <ShellContent
            Title="Stats"
            Icon="{OnPlatform iOS='chart', Default='chart'}"
            ContentTemplate="{DataTemplate views:StatsPage}"
            Route="StatsPage" />
    </TabBar>

</Shell>
